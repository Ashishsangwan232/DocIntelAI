# Only needed to point a local frontend at a backend that ISN'T
# localhost:8000 (e.g. a deployed Render API). Leave unset for normal
# local development — the Vite dev-server proxy (vite.config.js)
# already forwards /api/* to http://localhost:8000.
# VITE_API_BASE_URL=https://your-deployed-api.example.com/api/v1

# Only needed if your local FastAPI backend runs on a port other than
# 8000 — changes what the Vite dev-server proxy forwards to.
# VITE_API_PROXY_TARGET=http://localhost:8001
