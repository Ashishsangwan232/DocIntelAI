# =============================================================================
# DocIntel AI — Environment Variables Template
# Copy this file to `.env` and fill in real values for local development.
# In production (Render), set these directly in the service's Environment tab.
# NEVER commit a real `.env` file to version control.
# =============================================================================

# --- Application ---
APP_NAME=DocIntel AI
APP_ENV=development          # development | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --- Ollama Cloud (LLM) ---
LLM_PROVIDER=ollama_cloud
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
LLM_MODEL=gpt-oss:120b:Cloud
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60
LLM_STREAM=true

# --- Embeddings (Sentence-Transformers) ---
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true

# --- ChromaDB (Vector Store) ---
CHROMA_COLLECTION_NAME=docintel_documents
CHROMA_DISTANCE_METRIC=cosine

# --- SQLite (Metadata Store) ---
SQLITE_DB_NAME=docintel.db

# --- RAG / Chunking / Retrieval ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=5
SIMILARITY_SCORE_THRESHOLD=0.2

# --- Uploads ---
MAX_FILE_SIZE_MB=25
ALLOWED_EXTENSIONS=pdf,docx,txt,md
